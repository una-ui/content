{
  "name": "@una-ui/content",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@8.6.12",
  "description": "A Nuxt Content Theme built with UNA UI",
  "author": "Phojie Rengel <phojrengel@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/phojie",
  "homepage": "https://unaui.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/una-ui/content.git"
  },
  "bugs": "https://github.com/una-ui/content/issues",
  "keywords": [
    "nuxt-content",
    "nuxt-theme",
    "theme"
  ],
  "main": "./nuxt.config.ts",
  "files": [
    "nuxt.config.ts",
    "layouts",
    "components",
    "app.vue"
  ],
  "scripts": {
    "dev": "nuxi dev .starters/default",
    "build": "nuxi build .starters/default",
    "generate": "nuxi generate .starters/default",
    "preview": "nuxi preview .starters/default",
    "prepare": "nuxi prepare && nuxi prepare .starters/default",
    "postinstall": "npx simple-git-hooks",
    "lint": "eslint ."
  },
  "dependencies": {
    "@nuxt/content": "^2.7.2",
    "@nuxthq/studio": "^0.13.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.40.2",
    "@nexvelt/ui-nuxt": "npm:@nexvelt/ui-nuxt-edge@latest",
    "@unocss/eslint-config": "^0.55.1",
    "eslint": "^8.47.0",
    "nuxt": "^3.6.5",
    "simple-git-hooks": "^2.9.0",
    "typescript": "^5.1.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
